# =============================================================================
# .env.example  ―  非機密のデフォルト値のテンプレート
# -----------------------------------------------------------------------------
# このファイルをコピーして ".env" を作成すると、起動時のプロンプトで
# 入力を省略できる「デフォルト値」を設定できます（任意）。
#
#   copy .env.example .env      (Windows)
#
# 重要:
#   - .env は .gitignore 済みで、リポジトリにコミットされません。
#   - パスワードはここに書いても読み込まれません。常に起動時に
#     対話入力（getpass）されます。直書きは禁止です。
# =============================================================================

# 既定で選択したい口座のエイリアス（accounts.py の定義名）。例: live1
MT5_DEFAULT_ACCOUNT=

# 任意: ログイン番号のデフォルト（空ならプロンプトで入力）
# MT5_LOGIN=

# 任意: サーバー名のデフォルト（空ならプロンプト/選択）
# 例: OANDA-Japan Live / OANDA-Japan Demo
# MT5_SERVER=

# 任意: MetaTrader5 端末(terminal64.exe)のパス
# 既定の検出で見つからない場合のみ指定します。
# MT5_TERMINAL_PATH=C:\Program Files\OANDA MetaTrader 5\terminal64.exe
